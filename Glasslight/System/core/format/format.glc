package format;
require core.basic ~> .;
require core.string ~> str;
require core.atom ~> atoms;
require core.ffi.format ~> ffi;


+ format_element(val<s1>, out<{c1}*>) -> ()
{
	let buf<[c1, 32_sz]>;
	let n<size> = ffi.glc_format_s1(&buf[0_sz], 32_sz, val);
	out.append!(str.make_string_view(&buf[0_sz], n));

	^ ();
}

