package print;
require core.basic ~> .;
require core.string ~> .;

+ println(text<{c1, :c}>) -> atom
{
	if(!print(text))
	{
		^ :false;
	}

	^ print("\n");
}

+ println(text<{c1}>) -> atom
{
	println(text.to_cstring);
}

+ eprintln(text<{c1, :c}>) -> atom
{
	if(!eprint(text))
	{
		^ :false;
	}

	^ eprint("\n");
}

+ eprintln(text<{c1}>) -> atom
{
	eprintln(text.to_cstring);
}
